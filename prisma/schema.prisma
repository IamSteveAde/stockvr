// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id              Int          @unique @default(autoincrement())
  uid             String       @unique
  email           String       @unique
  password        String
  isBusinessOwner Boolean      @default(false)
  isFirstLogin    Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt
  pwdChangeAt     DateTime     @default(now())
  verified        Boolean      @default(false)
  userProfiles    UserProfile?
  // businessProfiles  BusinessProfile? @relation(fields: [businessProfileUid], references: [uid])
  // businessProfileId Int?
}

model BusinessProfile {
  id                      Int                      @id @default(autoincrement())
  uid                     String                   @unique
  userUid                 String                   @unique
  name                    String
  businessType            String
  location                String
  dailyStaffSize          String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  businessOwner           UserProfile?             @relation(fields: [userUid], references: [uid], name: "BusinessProfileToUserProfile")
  userProfiles            UserProfile[]            @relation("UserProfiletoBusiness")
  baseShifts              BaseShift[]
  shiftAssignments        ShiftAssignment[]
  shifts                  Shift[]
  // users            Users[]
  products                Products[]
  auditTrails             AuditTrail[]
  stockEntries            StockEntry[]
  endShiftEntries         EndShiftEntry[]
  variances               Variance[]
  shiftContexts           ShiftContext[]
  inventoryTotalVariances InventoryTotalVariance[]
  inventories             Inventory[]
  subscription            Subscriptions[]
}

model UserProfile {
  id               Int               @id @default(autoincrement())
  uid              String            @unique
  status           String            @default("Active")
  accessType       String
  userId           String            @unique
  phoneNo          String?
  name             String?
  profileUrl       String?
  pin              String?
  businessUid      String?
  business         BusinessProfile?  @relation(fields: [businessUid], references: [uid], name: "UserProfiletoBusiness")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  owner            Users             @relation(fields: [userId], references: [uid])
  shiftAssignments ShiftAssignment[]
  shiftsInCharge   BaseShift[]       @relation("staffInCharge")
  shifts           Shift[]
  businessProfile  BusinessProfile?  @relation("BusinessProfileToUserProfile")
  auditTrails      AuditTrail[]
  stockEntries     StockEntry[]
}

model BaseShift {
  id              Int               @id @default(autoincrement())
  uid             String            @unique
  name            String
  businessUid     String
  startTime       String
  endTime         String
  startDate       DateTime?
  endDate         DateTime?
  isWeekly        Boolean           @default(false)
  repeatsOn       String[] //this is days of the week //for postgresql
  // repeatsOn       Json //this is days/ of the week
  staffInChargeId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  owningBusiness  BusinessProfile   @relation(fields: [businessUid], references: [uid])
  staffInCharge   UserProfile       @relation(fields: [staffInChargeId], references: [uid], name: "staffInCharge")
  linkedStaff     ShiftAssignment[]
  shifts          Shift[]
  auditTrails     AuditTrail[]
  stockEntries    StockEntry[]
  endShiftEntries EndShiftEntry[]
  variances       Variance[]
}

model ShiftAssignment {
  id             Int             @id @default(autoincrement())
  uid            String          @unique
  businessUid    String
  baseShiftUid   String
  staffUid       String
  assignedAt     DateTime        @default(now())
  owningBusiness BusinessProfile @relation(fields: [businessUid], references: [uid], onDelete: Cascade)
  baseShift      BaseShift       @relation(fields: [baseShiftUid], references: [uid], onDelete: Cascade)
  staff          UserProfile     @relation(fields: [staffUid], references: [uid], onDelete: Cascade)
  shifts         Shift[] // all generated shifts for this assignment

  @@unique([baseShiftUid, staffUid])
}

model Shift {
  id                 Int             @id @default(autoincrement())
  uid                String          @unique
  baseShiftUid       String
  businessUid        String
  shiftAssignmentUid String
  staffUid           String
  date               DateTime // the specific date of this shift occurrence
  startTime          String
  endTime            String
  status             String          @default("Pending")
  clockInTime        DateTime?
  // startInventoryItemCount Json[]
  clockOutTime       DateTime?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  owningBusiness     BusinessProfile @relation(fields: [businessUid], references: [uid])
  baseShift          BaseShift       @relation(fields: [baseShiftUid], references: [uid], onDelete: Cascade)
  assignment         ShiftAssignment @relation(fields: [shiftAssignmentUid], references: [uid])
  staff              UserProfile     @relation(fields: [staffUid], references: [uid])
  variances          Variance[]
  stockEntries       StockEntry[]
  endShiftEntries    EndShiftEntry[]
  shiftContext       ShiftContext?

  @@unique([shiftAssignmentUid, date]) // one shift per assignment per day
  @@index([staffUid, date]) // fast lookups by staff and date
  @@index([baseShiftUid, date]) // fast lookups by base shift and date
}

model Products {
  id          Int    @id @default(autoincrement())
  uid         String @unique
  name        String
  unit        String
  businessUid String

  status      String          @default("Active")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  inventory   Inventory?
  business    BusinessProfile @relation(references: [uid], fields: [businessUid], onDelete: Cascade)
  auditTrails AuditTrail[]
}

model Inventory {
  id                      Int                     @id @default(autoincrement())
  uid                     String                  @unique
  businessUid             String?
  productUid              String                  @unique
  quantity                Int                     @default(0)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  isLocked                Boolean                 @default(true)
  product                 Products                @relation(references: [uid], fields: [productUid], onDelete: Cascade)
  stockEntries            StockEntry[]
  endShiftEntries         EndShiftEntry[]
  variances               Variance[]
  inventoryTotalVariances InventoryTotalVariance?
  business                BusinessProfile?        @relation(references: [uid], fields: [businessUid], onDelete: Cascade)
}

model AuditTrail {
  id          Int             @id @default(autoincrement())
  staffUid    String
  businessUid String
  action      String
  shiftUid    String?
  productUid  String?
  detail      String
  entity      String
  staff       UserProfile     @relation(fields: [staffUid], references: [uid])
  shift       BaseShift?      @relation(fields: [shiftUid], references: [uid])
  product     Products?       @relation(fields: [productUid], references: [uid])
  business    BusinessProfile @relation(references: [uid], fields: [businessUid])
  createdAt   DateTime        @default(now())
}

model StockEntry {
  id                 Int             @id @default(autoincrement())
  inventoryUid       String
  shiftUid           String
  baseShiftUid       String
  staffUid           String
  businessUid        String
  action             String
  quantity           Int
  reason             String?
  createdAt          DateTime        @default(now())
  staff              UserProfile     @relation(fields: [staffUid], references: [uid])
  business           BusinessProfile @relation(fields: [businessUid], references: [uid])
  baseShift          BaseShift       @relation(fields: [baseShiftUid], references: [uid])
  staffInChargeShift Shift           @relation(fields: [shiftUid], references: [uid])
  linkedInventory    Inventory       @relation(fields: [inventoryUid], references: [uid])
}

model EndShiftEntry {
  id Int @unique @default(autoincrement())

  shiftUid String

  baseShiftUid       String
  inventoryUid       String
  count              Int
  initialCount       Int
  createdAt          DateTime        @default(now())
  businessUid        String
  business           BusinessProfile @relation(fields: [businessUid], references: [uid])
  linkedInventory    Inventory       @relation(fields: [inventoryUid], references: [uid])
  baseShift          BaseShift       @relation(fields: [baseShiftUid], references: [uid])
  staffInChargeShift Shift           @relation(fields: [shiftUid], references: [uid])
}

model Variance {
  id                 Int             @unique @default(autoincrement())
  shiftUid           String
  baseShiftUid       String
  inventoryUid       String
  openingCount       Int             @default(0)
  addedCount         Int             @default(0)
  usedCount          Int             @default(0)
  actualCount        Int
  expectedCount      Int
  variance           Int
  createdAt          DateTime        @default(now())
  businessUid        String
  business           BusinessProfile @relation(fields: [businessUid], references: [uid])
  linkedInventory    Inventory       @relation(fields: [inventoryUid], references: [uid])
  staffInChargeShift Shift           @relation(fields: [shiftUid], references: [uid])
  baseShift          BaseShift       @relation(fields: [baseShiftUid], references: [uid])
}

model InventoryTotalVariance {
  id              Int             @unique @default(autoincrement())
  inventoryUid    String          @unique
  actualCount     Int
  expectedCount   Int
  variance        Int
  createdAt       DateTime        @default(now())
  businessUid     String
  business        BusinessProfile @relation(fields: [businessUid], references: [uid])
  linkedInventory Inventory       @relation(fields: [inventoryUid], references: [uid])
}

model ShiftContext {
  id                 Int             @id @default(autoincrement())
  businessUid        String
  shiftUid           String          @unique
  itemAffectedCount  Int
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now()) @updatedAt
  business           BusinessProfile @relation(fields: [businessUid], references: [uid])
  staffInChargeShift Shift           @relation(fields: [shiftUid], references: [uid])
}

model Subscriptions {
  id Int @id @default(autoincrement())

  subscriptionRef    String   @unique
  businessProfileUid String
  startAt            DateTime @default(now())
  endAt              DateTime
  isTrial            Boolean  @default(true)
  isActive           Boolean  @default(true)
  linkedCode         String?
  linkedEmailToken   String?
  createdAt          DateTime @default(now())

  business     BusinessProfile @relation(fields: [businessProfileUid], references: [uid])
  transactions Transactions[]
}

model Transactions {
  id              Int      @id @default(autoincrement())
  trxRef          String   @unique
  status          String   @default("Pending")
  amount          Int      @default(0)
  currency        String   @default("NGN")
  source          String   @default("Paystack")
  subscriptionRef String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt 

  subscription Subscriptions? @relation(fields: [subscriptionRef], references: [subscriptionRef])
}
